# ============================================
# CHARON ULTIMATE — Environment Configuration
# ============================================
# Copy to .env and fill in your API keys
# DO NOT commit .env to git
# ============================================

# ============================================
# TELEGRAM (Required)
# ============================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ============================================
# SIGNAL SERVER (Required for Charon)
# ============================================
SIGNAL_SERVER_URL=https://api.thecharon.xyz/api
SIGNAL_SERVER_KEY=your_signal_server_key_here

# ============================================
# SOLANA RPC (Required)
# ============================================
HELIUS_API_KEY=your_helius_api_key_here

# ============================================
# TRADING MODE
# ============================================
# dry_run = simulated trades (safe, no real money)
# confirm = asks for approval before each trade
# live = executes trades automatically
TRADING_MODE=dry_run

# ============================================
# WALLET (Required only for live/confirm mode)
# ============================================
SOLANA_PRIVATE_KEY=your_private_key_here
LIVE_MIN_SOL_RESERVE=0.02
JUPITER_API_KEY=your_jupiter_api_key_here
JUPITER_SLIPPAGE_BPS=300

# ============================================
# GMGN API (Required)
# ============================================
GMGN_API_KEY=your_gmgn_api_key_here
GMGN_ENABLED=true

# ============================================
# LLM CONFIGURATION
# ============================================
LLM_BASE_URL=https://api.minimax.io/v1
LLM_API_KEY=your_llm_api_key_here
LLM_MODEL=MiniMax-M2.7
LLM_TIMEOUT_MS=60000
ENABLE_LLM=true

# ============================================
# TWITTER/X SENTIMENT (Optional)
# ============================================
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# ============================================
# POLLING INTERVALS
# ============================================
SIGNAL_POLL_MS=30000
POSITION_CHECK_MS=10000
GRADUATED_POLL_MS=30000
TRENDING_POLL_MS=60000

# ============================================
# DATABASE
# ============================================
DB_PATH=./charon.sqlite